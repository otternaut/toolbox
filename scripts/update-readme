#!/usr/bin/env bash
#
# update-readme — regenerate the "Available skills" table in README.md from the
# frontmatter of every skills/<name>/SKILL.md.
#
# The table lives between these markers in README.md:
#   <!-- BEGIN SKILLS TABLE ... -->
#   <!-- END SKILLS TABLE -->
# Everything between them is replaced with a freshly generated table. Each row
# links to the skill and shows the first sentence of its `description`.
#
# No dependencies beyond bash + coreutils + awk.
#
# Usage:
#   ./scripts/update-readme            Rewrite README.md in place.
#   ./scripts/update-readme --check    Exit non-zero if README.md is stale
#                                      (for CI / hooks); do not modify anything.
#   ./scripts/update-readme -h|--help  Show this help.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SKILLS_SRC="$REPO_ROOT/skills"
README="$REPO_ROOT/README.md"

BEGIN_MARKER='<!-- BEGIN SKILLS TABLE (auto-generated by scripts/update-readme — do not edit by hand) -->'
END_MARKER='<!-- END SKILLS TABLE -->'

CHECK=0

usage() {
  cat <<EOF
update-readme — regenerate the skills table in README.md from SKILL.md frontmatter.

Usage: ./scripts/update-readme [options]

Options:
  --check      Exit 1 if README.md is out of date; do not modify it.
  -h, --help   Show this help.
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --check) CHECK=1 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "update-readme: unknown option '$1'" >&2; usage >&2; exit 2 ;;
  esac
  shift
done

[ -d "$SKILLS_SRC" ] || { echo "update-readme: no skills directory at $SKILLS_SRC" >&2; exit 1; }
[ -f "$README" ]     || { echo "update-readme: no README.md at $README" >&2; exit 1; }

# Extract a field from a SKILL.md YAML frontmatter block. Supports a value on
# the same line ("name: foo") and folded/literal block scalars ("description: >"
# followed by indented lines). Prints the field's value on one line.
frontmatter_field() {
  local file="$1" field="$2"
  awk -v field="$field" '
    NR == 1 { if ($0 ~ /^---[[:space:]]*$/) { infm = 1; next } }
    infm && /^---[[:space:]]*$/ { exit }
    !infm { next }
    {
      if (collecting) {
        if ($0 ~ /^[[:space:]]+/) {                 # still inside the block scalar
          line = $0; sub(/^[[:space:]]+/, "", line)
          val = (val == "" ? line : val " " line)
          next
        } else { collecting = 0 }                    # dedented — block ended
      }
      # Match "<field>:" at the start of a frontmatter line.
      if ($0 ~ "^" field ":") {
        rest = $0; sub("^" field ":[[:space:]]*", "", rest)
        if (rest == ">" || rest == "|" || rest == ">-" || rest == "|-") {
          collecting = 1; val = ""; next            # begin block scalar
        }
        val = rest
      }
    }
    END { print val }
  ' "$file"
}

# First sentence of a string: up to the first ". " or a trailing ".".
first_sentence() {
  awk '{
    s = $0
    if (match(s, /\.([[:space:]]|$)/)) s = substr(s, 1, RSTART)
    print s
  }' <<<"$1"
}

# --- build the table ---------------------------------------------------------
build_table() {
  printf '%s\n' "$BEGIN_MARKER"
  printf '| Skill | What it does |\n'
  printf '| --- | --- |\n'
  for dir in "$SKILLS_SRC"/*/; do
    [ -d "$dir" ] || continue
    [ -f "$dir/SKILL.md" ] || continue
    local name desc
    name="$(basename "$dir")"
    desc="$(first_sentence "$(frontmatter_field "$dir/SKILL.md" description)")"
    desc="${desc:-No description.}"
    printf '| [`%s`](skills/%s/SKILL.md) | %s |\n' "$name" "$name" "$desc"
  done
  printf '%s\n' "$END_MARKER"
}

# --- splice the table into README between the markers ------------------------
# Write the freshly built table to a temp file; awk streams it in at the marker
# (passing a multi-line table via `-v` breaks on BSD awk).
TABLE_FILE="$(mktemp)"
trap 'rm -f "$TABLE_FILE"' EXIT
build_table > "$TABLE_FILE"

RENDERED="$(
  awk -v begin="$BEGIN_MARKER" -v end="$END_MARKER" -v tablefile="$TABLE_FILE" '
    $0 == begin { while ((getline line < tablefile) > 0) print line; skip = 1; next }
    $0 == end   { skip = 0; next }
    !skip       { print }
  ' "$README"
)"

# Guard: the markers must exist, otherwise we would silently drop the table.
if ! grep -qF "$BEGIN_MARKER" "$README" || ! grep -qF "$END_MARKER" "$README"; then
  echo "update-readme: could not find the skills-table markers in README.md" >&2
  echo "  expected a block delimited by:" >&2
  echo "    $BEGIN_MARKER" >&2
  echo "    $END_MARKER" >&2
  exit 1
fi

if [ "$CHECK" -eq 1 ]; then
  if [ "$RENDERED" != "$(cat "$README")" ]; then
    echo "update-readme: README.md is out of date. Run ./scripts/update-readme." >&2
    exit 1
  fi
  echo "update-readme: README.md is up to date."
  exit 0
fi

if [ "$RENDERED" = "$(cat "$README")" ]; then
  echo "update-readme: README.md already up to date."
  exit 0
fi

printf '%s\n' "$RENDERED" > "$README"
echo "update-readme: README.md skills table refreshed."
